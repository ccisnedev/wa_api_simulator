# Puerto del servidor REST
PORT=3001

# Baileys — número que usa el simulador para enviar/recibir
PHONE_NUMBER=51999000000

# Compatibilidad con WhatsApp Cloud API de Meta
PHONE_NUMBER_ID=sim_pnid_001
WABA_ID=sim_waba_001
ACCESS_TOKEN=sim_access_token

# Webhook — URL donde se enviarán los eventos entrantes
CALLBACK_URL=http://localhost:8080/webhooks/whatsapp
VERIFY_TOKEN=my_verify_secret
APP_SECRET=my_app_secret

# Media storage
MEDIA_DIR=./media
MEDIA_MAX_SIZE_MB=100
